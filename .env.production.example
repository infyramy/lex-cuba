# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  CORRAD Laravel CMS — Production Environment                             ║
# ║                                                                           ║
# ║  Copy to .env → edit values → docker compose up -d --build               ║
# ║  See DOCKER.md for full setup guide.                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=LexSZA
APP_ENV=production
APP_KEY=                              # Auto-generated on first run, or: php artisan key:generate
APP_DEBUG=false                       # NEVER true in production
APP_URL=https://api.your-domain.com   # Your API domain

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# When using Docker Compose, DB_HOST must be "db" (the service name)
DB_CONNECTION=pgsql
DB_HOST=db                            # Docker: "db" | Bare metal: "127.0.0.1"
DB_PORT=5432
DB_DATABASE=corrad
DB_USERNAME=corrad
DB_PASSWORD=changeme                  # CHANGE THIS — use a strong password

# ── Sessions ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.your-domain.com       # Leading dot = shared across subdomains
SESSION_SECURE_COOKIE=true

# ── Sanctum (SPA + Mobile Auth) ──────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=admin.your-domain.com,api.your-domain.com
FRONTEND_URL=https://admin.your-domain.com
SANCTUM_TOKEN_EXPIRATION=43200        # Mobile token expiry: 30 days (in minutes)

# ── Admin Panel Frontend Build ────────────────────────────────────────────────
# This URL is baked into the Vue SPA at build time.
# It tells the admin panel where to find the API.
VITE_API_BASE_URL=https://api.your-domain.com

# ── Admin Seed Credentials ───────────────────────────────────────────────────
# Used only on first run when database is empty. Change after first login.
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345             # CHANGE THIS after first login

# ── Docker Ports (only used by docker-compose) ───────────────────────────────
API_PORT=8080
ADMIN_PORT=8081

# ── Drivers ───────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
